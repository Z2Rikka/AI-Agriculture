# ============================================================
# 智能农业灌溉系统 - 环境变量示例文件
# ============================================================
DATABASE_URL="postgresql://user:password@localhost:5432/eps32db?schema=public"

# MQTT Broker（EMQX / Mosquitto）
MQTT_BROKER_URL=mqtt://<your-mqtt-server-ip>:1883
MQTT_USERNAME=
MQTT_PASSWORD=

# JWT（预留，若后续需要用户名+密码登录而非纯 API Key）
JWT_SECRET=
JWT_EXPIRES_IN=

# 后端服务端口
PORT=3000

# 山东仁科环境云平台账号
RENKE_LOGIN_NAME=
RENKE_PASSWORD=

# 注册管理员接口验证密钥 (仅知道该密钥的人可注册账号获取 API Key)
ADMIN_REGISTRATION_SECRET=
