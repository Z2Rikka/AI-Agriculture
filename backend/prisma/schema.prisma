// ============================================================
// 智能农业灌溉系统 - Prisma Schema
// Multi-tenant IoT Backend with API Key auth + MQTT control
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ------------------------------------------------------------
// 用户表：每个用户有独立的 API_KEY，支持多租户管理
// ------------------------------------------------------------
model User {
  id          String   @id @default(uuid())
  username    String   @unique              // 登录用户名
  password    String                        // Bcrypt 哈希后的密码（预留，非 API Key 场景）
  apiKey      String   @unique              // 用户的唯一 API_KEY（Bearer Token）
  apiKeyAlias String?  @default("")        // Key 的别名/备注，方便管理
  isActive    Boolean  @default(true)       // 禁用后该 Key 立即失效
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  lastUsedAt  DateTime?                     // 最后一次调用 API 的时间

  // 关联：一个用户可以绑定多台设备
  devices Device[]

  @@map("users")
}

// ------------------------------------------------------------
// 设备表：记录 ESP32 硬件设备的状态与归属
// ------------------------------------------------------------
model Device {
  id           String   @id @default(uuid())
  deviceId     String   @unique              // 物理设备编号，如 "ESP32_001"
  deviceName   String   @default("")          // 设备别名，如 "1号大棚灌溉阀"
  deviceType   String   @default("ESP32")    // 设备类型：ESP32 / STM32 / etc.
  deviceSecret String?                        // 设备端认证密钥（可选，用于设备固件 OTA）

  // 在线状态
  isOnline     Boolean  @default(false)       // 设备是否在线
  lastOnlineAt DateTime?

  // 归属用户（多租户隔离）
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // 关系：一个设备可产生多条日志
  irrigationLogs IrrigationLog[]
  // 关系：传感器数据历史
  sensorData     SensorData[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("devices")
}

// ------------------------------------------------------------
// 传感器数据表：记录设备上传的环境参数历史
// ------------------------------------------------------------
model SensorData {
  id              String   @id @default(uuid())
  deviceId        String
  device          Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  airTemperature  Float?   // 空气温度 ℃
  airHumidity     Float?   // 空气湿度 %
  soilTemperature Float?   // 土壤温度 ℃
  soilHumidity    Float?   // 土壤湿度 %
  illuminance     Float?   // 光照度 Lux
  batteryLevel    Float?   // 电池电量 %
  
  // JSON 扩展字段保存其他未知传感器数据
  extraData       Json?

  timestamp       DateTime @default(now()) // 数据采集时间

  @@index([deviceId, timestamp])
  @@map("sensor_data")
}

// ------------------------------------------------------------
// 灌溉日志表：记录每次灌溉操作的完整轨迹
// ------------------------------------------------------------
model IrrigationLog {
  id         String   @id @default(uuid())
  deviceId   String
  device     Device   @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  // 操作来源
  trigger    String   @default("API")         // API | SCHEDULE | SENSOR | MANUAL
  triggerBy  String?                        // 触发者：User.username / "AI_Agent" / "Sensor"

  // 指令内容
  command    String                        // ON / OFF
  topic      String                        // 发布到的 MQTT 主题

  // 传感器数据（触发时或当前状态）
  soilMoisture  Float?                     // 土壤湿度 0~100%
  temperature   Float?                     // 温度 摄氏度
  humidity      Float?                     // 空气湿度 0~100%

  // 状态（用于追诉）
  status     String   @default("PENDING")   // PENDING | SUCCESS | FAILED | TIMEOUT

  // 时间戳
  issuedAt   DateTime @default(now())      // 指令下发时间
  completedAt DateTime?                    // 指令完成时间（设备响应）

  @@index([deviceId, issuedAt])
  @@map("irrigation_logs")
}
